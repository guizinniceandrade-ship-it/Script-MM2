-- Lógica do Fly (Voo)
local flying = false
local speedfly = 50
local function toggleFly(v)
    flying = v
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    if flying then
        local bv = Instance.new("BodyVelocity", char.HumanoidRootPart)
        bv.Name = "FlyVelocity"
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        local bg = Instance.new("BodyGyro", char.HumanoidRootPart)
        bg.Name = "FlyGyro"
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        task.spawn(function()
            while flying do
                rs.RenderStepped:Wait()
                char.Humanoid.PlatformStand = true
                bv.Velocity = char.Humanoid.MoveDirection * speedfly + Vector3.new(0, 0.1, 0)
                bg.CFrame = cam.CFrame
            end
            char.Humanoid.PlatformStand = false
            if char.HumanoidRootPart:FindFirstChild("FlyVelocity") then char.HumanoidRootPart.FlyVelocity:Destroy() end
            if char.HumanoidRootPart:FindFirstChild("FlyGyro") then char.HumanoidRootPart.FlyGyro:Destroy() end
        end)
    end
end

-- Botões de Ligar/Desligar
local function AddToggle(parent, texto, callback)
    local f = Instance.new("TextButton", parent)
    f.Size = UDim2.new(1, -10, 0, 35)
    f.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    f.Text = "  [ " .. texto .. " ]"
    f.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    f.TextXAlignment = Enum.TextXAlignment.Left
    f.Font = Enum.Font.GothamSemibold
    f.TextSize = 11
    Instance.new("UICorner", f)
    local status = Instance.new("TextLabel", f)
    status.Size = UDim2.new(0, 60, 1, 0)
    status.Position = UDim2.new(1, -65, 0, 0)
    status.Text = "OFF"
    status.TextColor3 = Color3.new(0.5, 0.5, 0.5)
    status.BackgroundTransparency = 1
    status.Font = Enum.Font.GothamBold
    local ligado = false
    f.MouseButton1Click:Connect(function()
        ligado = not ligado
        status.Text = ligado and "ON" or "OFF"
        status.TextColor3 = ligado and cor_neon or Color3.new(0.5, 0.5, 0.5)
        f.BackgroundColor3 = ligado and Color3.fromRGB(40, 30, 30) or Color3.fromRGB(30, 30, 30)
        callback(ligado)
    end)
end

