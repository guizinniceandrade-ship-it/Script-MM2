-- ✅ LOOP PRINCIPAL EXATAMENTE O SEU
task.spawn(function()
    while task.wait(0.5) do
        -- Lógica ESP
        if states.esp then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= lp and p.Character then
                    local h = p.Character:FindFirstChild("Highlight") or Instance.new("Highlight", p.Character)
                    local isM = p.Backpack:FindFirstChild("Knife") or p.Character:FindFirstChild("Knife")
                    local isS = p.Backpack:FindFirstChild("Gun") or p.Character:FindFirstChild("Gun")
                    h.FillColor = isM and Color3.new(1,0,0) or (isS and Color3.new(0,0,1) or Color3.new(0,1,0))
                end
            end
        end

        -- Lógica Auto Farm (Procura moedas no mapa)
        if states.autoFarm and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(game.Workspace:GetDescendants()) do
                if v.Name == "Coin" or v.Name == "CoinContainer" or v:FindFirstChild("CoinVisual") then
                    if v:IsA("BasePart") or v:IsA("Model") then
                        local pos = v:IsA("Model") and v:GetModelCFrame().Position or v.Position
                        lp.Character.HumanoidRootPart.CFrame = CFrame.new(pos)
                        task.wait(0.1) -- Pequena pausa para coletar
                        break -- Foca em uma moeda por vez
                    end
                end
            end
        end
    end
end)

-- ✅ LOOP DE NOCLIP E VELOCIDADE IGUAL AO SEU
RunService.Stepped:Connect(function()
    if lp.Character and lp.Character:FindFirstChild("Humanoid") then
        if states.noclip then
            for _, v in pairs(lp.Character:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
        if states.speed then
            lp.Character.Humanoid.WalkSpeed = 60
        else
            lp.Character.Humanoid.WalkSpeed = 16
        end
    end
end)

-- ✅ PULO INFINITO IGUAL AO SEU
UIS.JumpRequest:Connect(function()
    if states.infJump and lp.Character and lp.Character:FindFirstChild("Humanoid") then
        lp.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

